# Environment Variables Configuration
# Copy this file to .env, .env.opBNB, .env.opBNBTestnet, .env.bnbTestnet, or .env.sepolia and fill in your values

# ============================================
# Network RPC URLs
# ============================================

# Ethereum Sepolia Testnet
ETH_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
ETH_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# BNB Chain Testnet (BSC Testnet)
BSC_TESTNET_RPC_URL=https://bsc-testnet.nodereal.io/v1/YOUR_API_KEY
BNB_TESTNET_RPC_URL=https://bsc-testnet.nodereal.io/v1/YOUR_API_KEY

# opBNB Mainnet
OPBNB_RPC_URL=https://opbnb-mainnet.nodereal.io/v1/YOUR_API_KEY
OPBNB_MAINNET_RPC_URL=https://opbnb-mainnet.nodereal.io/v1/YOUR_API_KEY

# opBNB Testnet (NodeReal)
OPBNB_TESTNET_RPC_URL=https://opbnb-testnet.nodereal.io/v1/e59b1bd6360a4cdf9a39530a77e815ca

# Infura (optional, for Ethereum networks)
INFURA_ID=your_infura_project_id

# ============================================
# Account Configuration
# ============================================

# Private Key (use either PRIVATE_KEY or MNEMONIC, not both)
PRIVATE_KEY=your_private_key_here

# Mnemonic (use either PRIVATE_KEY or MNEMONIC, not both)
MNEMONIC=your twelve word mnemonic phrase here
ACCOUNT_INDEX=0

# Mnemonic File (alternative to MNEMONIC env var)
MNEMONIC_FILE=.mnemonic

# ============================================
# Gas Price Configuration
# ============================================

# Sepolia Gas Price (in wei, default: 20000000000 = 20 gwei)
SEPOLIA_GAS_PRICE=20000000000

# BSC Testnet Gas Price (in wei, default: 20000000000 = 20 gwei)
BSC_TESTNET_GAS_PRICE=20000000000
BNB_TESTNET_GAS_PRICE=20000000000

# opBNB Gas Price (in wei, default: 1000000000 = 1 gwei)
OPBNB_GAS_PRICE=1000000000
OPBNB_TESTNET_GAS_PRICE=1000000000

# ============================================
# Network Timeout
# ============================================
NETWORK_TIMEOUT=60000

# ============================================
# Deployment Configuration
# ============================================
SALT=0x0a59dbff790c23c976a548690c27297883cc66b4c67024f9117b0238995e35e9

# EntryPoint Address (required for BNB Testnet and opBNB Testnet deployments)
# This should be the address of a pre-deployed EntryPoint contract on the target network
ENTRYPOINT=0xYourEntryPointAddressHere

# ============================================
# Environment Mode
# ============================================
NODE_ENV=development
HARDHAT_NETWORK=localhost
NETWORK=localhost
